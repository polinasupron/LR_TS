{
    "compilerOptions": {
        "target": "ES6",
        "module": "ESNext",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "baseUrl": "./src",
        "lib": ["DOM", "ESNext"],
        "types": ["node", "webpack-env"]
    },
    "include": ["src"]
}

